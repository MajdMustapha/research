# Required
# ANTHROPIC_API_KEY is NOT needed — analyst uses `claude` CLI (Max subscription)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_OPERATOR_CHAT_ID=...
POLYMARKET_PRIVATE_KEY=0x...        # Never in config file on VPS, always env var

# Polymarket config
POLYMARKET_CHAIN_ID=137             # Polygon mainnet
POLYMARKET_SIGNATURE_TYPE=proxy     # default

# Optional — activate when ready
NEWSAPI_KEY=...
ALCHEMY_API_KEY=...

# System
LOG_LEVEL=INFO
DATA_DIR=data
