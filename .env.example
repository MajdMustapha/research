# Polymarket — CLI handles auth; wallet address needed for data queries
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_WALLET_ADDRESS=0x...

# Trading mode — NEVER set to true until backtest gate_passed=True
LIVE_MODE=false

# Telegram alerts (optional — if absent, alerts silently skipped)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# No weather API key needed — IEM (Iowa State University) is free, no auth required
