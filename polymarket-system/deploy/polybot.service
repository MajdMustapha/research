[Unit]
Description=Polymarket Niche Trading Bot (Poly//Watch)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/research/polymarket-system
EnvironmentFile=/home/ubuntu/research/polymarket-system/.env
ExecStart=/home/ubuntu/research/polymarket-system/.venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
