//@version=5
strategy("Bounce Setup", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=2, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.1, max_labels_count=300)

// ╔══════════════════════════════════════════════════════════════╗
// ║  High Probability Bounce Setup (Equities)                   ║
// ║                                                              ║
// ║  3 MANDATORY confluences (must have ALL):                   ║
// ║    1. Strong Support (EMA tested, Fib, horizontal, trend)   ║
// ║    2. Stochastics Oversold (%K & %D < 30)                  ║
// ║    3. Candlestick Reversal Pattern + next-day confirmation  ║
// ║                                                              ║
// ║  PLUS factors (improve conviction):                         ║
// ║    - MACD bullish or no bearish cross within 5 bars         ║
// ║    - Wave pattern (higher lows, EMA stack)                  ║
// ║    - Smooth retracement before reversal                     ║
// ║    - SPY trend filter (above 50 EMA = bullish regime)       ║
// ╚══════════════════════════════════════════════════════════════╝

// === INPUTS ===
// Stochastics
stochK      = input.int(14, "Stoch %K Length", group="1. Stochastics")
stochD      = input.int(3,  "Stoch %D Smooth", group="1. Stochastics")
stochSmooth = input.int(3,  "Stoch %K Smooth", group="1. Stochastics")
stochOS     = input.int(30, "Stoch Oversold", group="1. Stochastics")
stochOB     = input.int(70, "Stoch Overbought", group="1. Stochastics")

// MACD
macdFast    = input.int(50,  "MACD Fast", group="2. MACD")
macdSlow    = input.int(100, "MACD Slow", group="2. MACD")
macdSig     = input.int(9,   "MACD Signal", group="2. MACD")
macdLookback = input.int(5,  "MACD Cross Lookback", group="2. MACD")

// EMAs
emaFastLen  = input.int(50,  "EMA Fast", group="3. EMAs")
emaMidLen   = input.int(100, "EMA Mid", group="3. EMAs")
emaSlowLen  = input.int(200, "EMA Slow", group="3. EMAs")
emaTouchPct = input.float(0.3, "EMA Touch Distance %", group="3. EMAs") / 100
minTouches  = input.int(2,   "Min Prior EMA Touches", group="3. EMAs")

// Support
fibLen      = input.int(50,  "Fib Swing Lookback", group="4. Support")
fibTol      = input.float(0.5, "Fib/Support Tolerance %", group="4. Support") / 100
horzLookback = input.int(50, "Horizontal S/R Lookback", group="4. Support")
horzMinTouches = input.int(2, "Min Horizontal Touches", group="4. Support")
trendLineLookback = input.int(30, "Trendline Lookback", group="4. Support")

// Volume
minVolume   = input.float(200000, "Min Daily Volume", group="5. Volume")

// Candlestick
bodyMinPct  = input.float(0.3, "Min Body % for Patterns", group="6. Candles") / 100

// SPY Filter
useSPYFilter = input.bool(true, "Use SPY Trend Filter", group="7. SPY Filter")
spyEmLen    = input.int(50, "SPY EMA Length", group="7. SPY Filter")

// Risk
atrLen      = input.int(14, "ATR Length", group="8. Risk")
atrSlMult   = input.float(1.5, "SL ATR Multiplier (1R)", group="7. Risk")
rrRatio     = input.float(3.0, "R:R Ratio (3R target)", group="7. Risk")

// === CORE CALCULATIONS ===
ema50   = ta.ema(close, emaFastLen)
ema100  = ta.ema(close, emaMidLen)
ema200  = ta.ema(close, emaSlowLen)
atrVal  = ta.atr(atrLen)

k = ta.sma(ta.stoch(close, high, low, stochK), stochSmooth)
d = ta.sma(k, stochD)

[macdLine, signalLine, macdHist] = ta.macd(close, macdFast, macdSlow, macdSig)

// SPY trend
spyClose = request.security("SPY", "D", close)
spyEma   = request.security("SPY", "D", ta.ema(close, spyEmLen))
spyBullish = spyClose > spyEma

// ═══════════════════════════════════════════════════════════════
// MANDATORY 1: STOCHASTICS OVERSOLD
// ═══════════════════════════════════════════════════════════════
stochOversold = k < stochOS and d < stochOS
// Was oversold on pattern day or day before
stochWasOS = stochOversold or stochOversold[1]

// ═══════════════════════════════════════════════════════════════
// MANDATORY 2: CANDLESTICK REVERSAL PATTERN + CONFIRMATION
// All patterns detected on candle[1], confirmation = current candle
// closes higher than pattern candle (next-day confirmation)
// ═══════════════════════════════════════════════════════════════

// Helper: candle metrics
bodySize(i) => math.abs(close[i] - open[i])
candleRange(i) => high[i] - low[i]
bodyRatio(i) => candleRange(i) > 0 ? bodySize(i) / candleRange(i) : 0
isBullish(i) => close[i] > open[i]
isBearish(i) => close[i] < open[i]
upperWick(i) => high[i] - math.max(close[i], open[i])
lowerWick(i) => math.min(close[i], open[i]) - low[i]

// --- Bullish Pin Bar (Hammer) ---
// Long lower wick (>= 2x body), small upper wick, body in upper third
pinBarBull_pattern = lowerWick(1) >= bodySize(1) * 2 and upperWick(1) <= bodySize(1) * 0.5 and bodySize(1) > 0
pinBarBull_confirm = close > high[1]  // next day closes above pattern high

// --- Bullish Engulfing ---
// Yesterday bearish, today's body fully engulfs yesterday's body
engulfBull_pattern = isBearish(2) and isBullish(1) and open[1] <= close[2] and close[1] >= open[2] and bodySize(1) > bodySize(2)
engulfBull_confirm = close > high[1]

// --- Bullish Harami ---
// Yesterday large bearish, today small bullish body within yesterday's range
haramiBull_pattern = isBearish(2) and isBullish(1) and open[1] > close[2] and close[1] < open[2] and bodySize(1) < bodySize(2) * 0.5
haramiBull_confirm = close > high[1]

// --- Morning Star (3-candle) ---
// Day -3: large bearish, Day -2: small body (star) gaps down, Day -1: large bullish
// Confirmation on current candle
morningStar_c3bear = isBearish(3) and bodyRatio(3) > bodyMinPct
morningStar_star   = bodySize(2) < bodySize(3) * 0.3  // small body star
morningStar_c1bull = isBullish(1) and bodyRatio(1) > bodyMinPct and close[1] > (open[3] + close[3]) / 2  // closes above midpoint of first candle
morningStar_pattern = morningStar_c3bear and morningStar_star and morningStar_c1bull
morningStar_confirm = close > high[1]

// --- White Soldier (single) ---
// Large bullish candle after a decline (prior candle was bearish)
whiteSoldier_pattern = isBearish(2) and isBullish(1) and bodyRatio(1) > 0.6 and bodySize(1) > bodySize(2)
whiteSoldier_confirm = close > high[1]

// Combined: any pattern + confirmation
bullPattern = (pinBarBull_pattern and pinBarBull_confirm) or (engulfBull_pattern and engulfBull_confirm) or (haramiBull_pattern and haramiBull_confirm) or (morningStar_pattern and morningStar_confirm) or (whiteSoldier_pattern and whiteSoldier_confirm)

// Identify which pattern for labeling
patternName = pinBarBull_pattern and pinBarBull_confirm ? "Pin Bar" : engulfBull_pattern and engulfBull_confirm ? "Engulfing" : haramiBull_pattern and haramiBull_confirm ? "Harami" : morningStar_pattern and morningStar_confirm ? "M.Star" : whiteSoldier_pattern and whiteSoldier_confirm ? "Soldier" : "None"

// --- Bearish mirrors ---
pinBarBear_pattern = upperWick(1) >= bodySize(1) * 2 and lowerWick(1) <= bodySize(1) * 0.5 and bodySize(1) > 0
pinBarBear_confirm = close < low[1]

engulfBear_pattern = isBullish(2) and isBearish(1) and open[1] >= close[2] and close[1] <= open[2] and bodySize(1) > bodySize(2)
engulfBear_confirm = close < low[1]

haramiBear_pattern = isBullish(2) and isBearish(1) and close[1] > open[2] and open[1] < close[2] and bodySize(1) < bodySize(2) * 0.5
haramiBear_confirm = close < low[1]

eveningStar_pattern = isBullish(3) and bodyRatio(3) > bodyMinPct and bodySize(2) < bodySize(3) * 0.3 and isBearish(1) and bodyRatio(1) > bodyMinPct and close[1] < (open[3] + close[3]) / 2
eveningStar_confirm = close < low[1]

blackCrow_pattern = isBullish(2) and isBearish(1) and bodyRatio(1) > 0.6 and bodySize(1) > bodySize(2)
blackCrow_confirm = close < low[1]

bearPattern = (pinBarBear_pattern and pinBarBear_confirm) or (engulfBear_pattern and engulfBear_confirm) or (haramiBear_pattern and haramiBear_confirm) or (eveningStar_pattern and eveningStar_confirm) or (blackCrow_pattern and blackCrow_confirm)

bearPatternName = pinBarBear_pattern and pinBarBear_confirm ? "Pin Bar" : engulfBear_pattern and engulfBear_confirm ? "Engulfing" : haramiBear_pattern and haramiBear_confirm ? "Harami" : eveningStar_pattern and eveningStar_confirm ? "E.Star" : blackCrow_pattern and blackCrow_confirm ? "Crow" : "None"

// ═══════════════════════════════════════════════════════════════
// MANDATORY 3: STRONG SUPPORT
// ═══════════════════════════════════════════════════════════════

// --- EMA Support (tested 2+ times prior) ---
var int ema50Touches  = 0
var int ema100Touches = 0
var int ema200Touches = 0

ema50Touch  = math.abs(low - ema50) / ema50 < emaTouchPct
ema100Touch = math.abs(low - ema100) / ema100 < emaTouchPct
ema200Touch = math.abs(low - ema200) / ema200 < emaTouchPct

if ema50Touch and not ema50Touch[1]
    ema50Touches += 1
if ema100Touch and not ema100Touch[1]
    ema100Touches += 1
if ema200Touch and not ema200Touch[1]
    ema200Touches += 1

nearTestedEma = (ema50Touch and ema50Touches >= minTouches) or (ema100Touch and ema100Touches >= minTouches) or (ema200Touch and ema200Touches >= minTouches)

// --- Fibonacci 50% / 61.8% ---
swingHi = ta.highest(high, fibLen)
swingLo = ta.lowest(low, fibLen)
fibRange = swingHi - swingLo
fib50  = swingHi - fibRange * 0.5
fib618 = swingHi - fibRange * 0.618
nearFib = math.abs(low - fib50) / close < fibTol or math.abs(low - fib618) / close < fibTol

// --- Horizontal Support ---
horzTouches = 0
for i = 1 to horzLookback
    if math.abs(low[i] - low) / close < fibTol
        horzTouches += 1
horizontalSupport = horzTouches >= horzMinTouches

// --- Trendline Support (rising lows) ---
// Check if current low is near a line connecting two prior pivot lows
pivLow = ta.pivotlow(low, 5, 2)
var float tl_low1 = na
var int   tl_bar1 = na
var float tl_low2 = na
var int   tl_bar2 = na

if not na(pivLow)
    tl_low1 := tl_low2
    tl_bar1 := tl_bar2
    tl_low2 := pivLow
    tl_bar2 := bar_index - 2

trendlineSupport = false
if not na(tl_low1) and not na(tl_low2) and tl_bar2 > tl_bar1 and tl_low2 > tl_low1
    // Rising trendline — project to current bar
    slope = (tl_low2 - tl_low1) / (tl_bar2 - tl_bar1)
    projected = tl_low2 + slope * (bar_index - tl_bar2)
    trendlineSupport := math.abs(low - projected) / close < fibTol

// Combined support
strongSupport = nearTestedEma or nearFib or horizontalSupport or trendlineSupport
supportType = nearTestedEma ? "EMA" : nearFib ? "Fib" : horizontalSupport ? "Horiz" : trendlineSupport ? "Trend" : "None"

// Bearish — strong resistance
nearTestedEmaR = (math.abs(high - ema50) / ema50 < emaTouchPct) or (math.abs(high - ema100) / ema100 < emaTouchPct) or (math.abs(high - ema200) / ema200 < emaTouchPct)
nearFibR = math.abs(high - (swingLo + fibRange * 0.5)) / close < fibTol or math.abs(high - (swingLo + fibRange * 0.618)) / close < fibTol
horzResist = 0
for i = 1 to horzLookback
    if math.abs(high[i] - high) / close < fibTol
        horzResist += 1
strongResist = nearTestedEmaR or nearFibR or horzResist >= horzMinTouches

// ═══════════════════════════════════════════════════════════════
// PLUS FACTORS
// ═══════════════════════════════════════════════════════════════

// MACD
macdBullish = macdLine > signalLine
macdNoBearCross = ta.barssince(ta.crossunder(macdLine, signalLine)) > macdLookback
macdLongPlus = macdBullish or macdNoBearCross

// Wave pattern
uptrendWave = ema50 > ema200
pivL = ta.pivotlow(low, 5, 2)
var float pLow1 = na
var float pLow2 = na
if not na(pivL)
    pLow2 := pLow1
    pLow1 := pivL
higherLows = not na(pLow1) and not na(pLow2) and pLow1 > pLow2
wavePlus = uptrendWave and higherLows

// Smooth retracement
retraceBars = 0
for i = 1 to 8
    if close[i] < close[i+1]
        retraceBars += 1
smoothRetrace = retraceBars >= 3 and isBullish(0)

// SPY filter
spyPlus = not useSPYFilter or spyBullish

// Plus score
plusScore = 0
if macdLongPlus
    plusScore += 1
if wavePlus
    plusScore += 1
if smoothRetrace
    plusScore += 1
if spyPlus
    plusScore += 1
if trendlineSupport
    plusScore += 1
if horizontalSupport
    plusScore += 1

// ═══════════════════════════════════════════════════════════════
// ENTRY — ALL 3 MANDATORY + any plus factors
// ═══════════════════════════════════════════════════════════════

// Volume filter — only liquid stocks/crypto
liquidEnough = volume > minVolume

longSignal  = stochWasOS and bullPattern and strongSupport and liquidEnough and strategy.position_size == 0
shortSignal = (k > stochOB and d > stochOB) and bearPattern and strongResist and liquidEnough and strategy.position_size == 0

// === POSITION MANAGEMENT ===
if longSignal
    sl = close - atrVal * atrSlMult
    tp = close + math.abs(close - sl) * rrRatio
    strategy.entry("Long", strategy.long)
    strategy.exit("Long TP/SL", "Long", limit=tp, stop=sl)

if shortSignal
    sl = close + atrVal * atrSlMult
    tp = close - math.abs(sl - close) * rrRatio
    strategy.entry("Short", strategy.short)
    strategy.exit("Short TP/SL", "Short", limit=tp, stop=sl)

// ═══════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════

plot(ema50,  "EMA 50",  color=color.new(#2196F3, 0), linewidth=1)
plot(ema100, "EMA 100", color=color.new(#FF9800, 0), linewidth=1)
plot(ema200, "EMA 200", color=color.new(#E91E63, 0), linewidth=2)

// Fib levels (when near)
plot(nearFib ? fib50 : na, "Fib 50%", color=color.new(#9C27B0, 30), style=plot.style_cross, linewidth=2)
plot(nearFib ? fib618 : na, "Fib 61.8%", color=color.new(#9C27B0, 30), style=plot.style_cross, linewidth=2)

// Signals
plotshape(longSignal, "Long Bounce", shape.triangleup, location.belowbar, #00E676, size=size.normal, text="BOUNCE")
plotshape(shortSignal, "Short Bounce", shape.triangledown, location.abovebar, #FF1744, size=size.normal, text="BOUNCE")

// Pattern labels
if longSignal
    label.new(bar_index, low, patternName + "\n+" + str.tostring(plusScore) + " plus", style=label.style_label_up, color=color.new(#00E676, 20), textcolor=color.white, size=size.small)
if shortSignal
    label.new(bar_index, high, bearPatternName + "\n+" + str.tostring(plusScore) + " plus", style=label.style_label_down, color=color.new(#FF1744, 20), textcolor=color.white, size=size.small)

// Stoch zone
bgcolor(stochOversold ? color.new(#2196F3, 95) : (k > stochOB and d > stochOB) ? color.new(#FF5722, 95) : na, title="Stoch Zone")

// === HIDDEN PLOTS for MCP ===
plot(k, "Stoch %K", display=display.status_line, color=color.new(color.purple, 100))
plot(d, "Stoch %D", display=display.status_line, color=color.new(color.purple, 100))
plot(macdHist, "MACD Hist", display=display.status_line, color=color.new(color.purple, 100))
plot(longSignal ? 1 : shortSignal ? -1 : 0, "Signal", display=display.status_line, color=color.new(color.purple, 100))
plot(plusScore, "Plus Score", display=display.status_line, color=color.new(color.purple, 100))

// ═══════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════

var table tbl = table.new(position.top_right, 2, 13, bgcolor=color.new(color.black, 15), border_width=1)

if barstate.islast
    table.cell(tbl, 0, 0, "BOUNCE SETUP", text_color=#FFD700, text_size=size.small)
    table.cell(tbl, 1, 0, "EQUITIES", text_color=#FFD700, text_size=size.small)

    // Mandatory 1: Stoch
    stCol = stochWasOS ? color.green : color.red
    table.cell(tbl, 0, 1, "☑ Stoch OS", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 1, stochWasOS ? "✓ " + str.tostring(k, "#") + "/" + str.tostring(d, "#") : "✗ " + str.tostring(k, "#"), text_color=stCol, text_size=size.small)

    // Mandatory 2: Candle pattern
    cpCol = bullPattern ? color.green : color.red
    table.cell(tbl, 0, 2, "☑ Pattern", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 2, bullPattern ? "✓ " + patternName : "✗ None", text_color=cpCol, text_size=size.small)

    // Mandatory 3: Support
    spCol = strongSupport ? color.green : color.red
    table.cell(tbl, 0, 3, "☑ Support", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 3, strongSupport ? "✓ " + supportType : "✗ None", text_color=spCol, text_size=size.small)

    // Volume
    volCol = liquidEnough ? color.green : color.red
    table.cell(tbl, 0, 4, "☑ Volume", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 4, liquidEnough ? "✓ " + str.tostring(volume, "#.#") : "✗ Low vol", text_color=volCol, text_size=size.small)

    // Plus factors
    table.cell(tbl, 0, 5, "＋ MACD", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 5, macdLongPlus ? "✓" : "✗", text_color=macdLongPlus ? color.green : color.gray, text_size=size.small)

    table.cell(tbl, 0, 6, "＋ Wave", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 6, wavePlus ? "✓ HL" : "✗", text_color=wavePlus ? color.green : color.gray, text_size=size.small)

    table.cell(tbl, 0, 7, "＋ Retrace", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 7, smoothRetrace ? "✓ Smooth" : "✗", text_color=smoothRetrace ? color.green : color.gray, text_size=size.small)

    table.cell(tbl, 0, 8, "＋ SPY", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 8, spyBullish ? "✓ Bull" : "✗ Bear", text_color=spyBullish ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 9, "＋ Trendline", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 9, trendlineSupport ? "✓" : "—", text_color=trendlineSupport ? color.green : color.gray, text_size=size.small)

    table.cell(tbl, 0, 10, "＋ Horizontal", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 10, horizontalSupport ? "✓" : "—", text_color=horizontalSupport ? color.green : color.gray, text_size=size.small)

    // Score
    table.cell(tbl, 0, 11, "PLUS SCORE", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 11, str.tostring(plusScore) + "/6", text_color=plusScore >= 4 ? color.green : plusScore >= 2 ? color.yellow : color.gray, text_size=size.small)

    // Signal
    allMandatory = stochWasOS and bullPattern and strongSupport and liquidEnough
    sigText = longSignal ? ">>> BOUNCE LONG <<<" : allMandatory and not longSignal ? "CONFIRMED (check)" : "NO SIGNAL"
    sigCol  = longSignal ? color.green : #333333
    table.cell(tbl, 0, 11, "SIGNAL", text_color=color.white, text_size=size.small)
    table.cell(tbl, 1, 11, sigText, text_color=sigCol, text_size=size.small)
