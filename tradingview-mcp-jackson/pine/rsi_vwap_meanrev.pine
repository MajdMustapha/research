//@version=5
strategy("RSI Divergence + VWAP Mean Reversion", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=3, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.1)

// ============================================================================
// INPUTS
// ============================================================================

// RSI Divergence
rsiLen        = input.int(14, "RSI Length", minval=5, maxval=30, group="RSI Divergence")
divLookback   = input.int(14, "Divergence Lookback Bars", minval=5, maxval=30, group="RSI Divergence")
divMinBars    = input.int(5, "Min Bars Between Pivots", minval=3, maxval=15, group="RSI Divergence")

// VWAP
vwapSrc       = input.source(hlc3, "VWAP Source", group="VWAP")

// Volatility Regime Filter
atrLen        = input.int(14, "ATR Length", minval=5, maxval=30, group="Volatility Filter")
atrSmaLen     = input.int(50, "ATR SMA Length (regime)", minval=20, maxval=100, group="Volatility Filter")
atrMaxMult    = input.float(1.8, "Max ATR / SMA(ATR) Ratio", minval=1.0, maxval=3.0, step=0.1, group="Volatility Filter")

// Volume Confirmation
volSmaLen     = input.int(20, "Volume SMA Length", minval=10, maxval=50, group="Volume")
volSpikeMult  = input.float(1.3, "Volume Spike Multiplier", minval=1.0, maxval=3.0, step=0.1, group="Volume")

// Risk Management
atrStopMult   = input.float(2.0, "ATR Stop Loss Multiplier", minval=0.5, maxval=4.0, step=0.1, group="Risk")
atrTrailMult  = input.float(1.5, "ATR Trailing Stop Multiplier", minval=0.5, maxval=3.0, step=0.1, group="Risk")
trailActivate = input.float(1.0, "ATR Profit to Activate Trail", minval=0.5, maxval=3.0, step=0.1, group="Risk")
maxBarsExit   = input.int(20, "Max Bars in Trade", minval=5, maxval=50, group="Risk")

// EMA Trend Context
emaLen        = input.int(100, "Trend EMA Length", minval=50, maxval=200, group="Trend")

// ============================================================================
// CALCULATIONS
// ============================================================================

// Core indicators
rsiVal    = ta.rsi(close, rsiLen)
vwapVal   = ta.vwap(vwapSrc)
atrVal    = ta.atr(atrLen)
atrSma    = ta.sma(atrVal, atrSmaLen)
volSma    = ta.sma(volume, volSmaLen)
ema100    = ta.ema(close, emaLen)

// ADX for regime awareness
[diPlus, diMinus, adxVal] = ta.dmi(14, 14)

// ============================================================================
// RSI DIVERGENCE DETECTION
// Bullish: price lower low, RSI higher low
// Bearish: price higher high, RSI lower high
// ============================================================================

// Find RSI pivot lows and highs
rsiPivotLow  = ta.pivotlow(rsiVal, divMinBars, divMinBars)
rsiPivotHigh = ta.pivothigh(rsiVal, divMinBars, divMinBars)

// Track previous pivot values
var float prevRsiLow     = na
var float prevPriceLow   = na
var int   prevRsiLowBar  = na
var float prevRsiHigh    = na
var float prevPriceHigh  = na
var int   prevRsiHighBar = na

// Current pivot values (shifted by divMinBars due to pivot detection lag)
currRsiLow   = rsiPivotLow
currPriceLow = ta.pivotlow(low, divMinBars, divMinBars)
currRsiHigh  = rsiPivotHigh
currPriceHigh = ta.pivothigh(high, divMinBars, divMinBars)

// Update bullish divergence pivots
bullDiv = false
if not na(currRsiLow)
    if not na(prevRsiLow) and (bar_index - divMinBars - prevRsiLowBar) <= divLookback
        // Price made lower low but RSI made higher low = bullish divergence
        if currPriceLow < prevPriceLow and currRsiLow > prevRsiLow
            bullDiv := true
    prevRsiLow    := currRsiLow
    prevPriceLow  := currPriceLow
    prevRsiLowBar := bar_index - divMinBars

// Update bearish divergence pivots
bearDiv = false
if not na(currRsiHigh)
    if not na(prevRsiHigh) and (bar_index - divMinBars - prevRsiHighBar) <= divLookback
        // Price made higher high but RSI made lower high = bearish divergence
        if currPriceHigh > prevPriceHigh and currRsiHigh < prevRsiHigh
            bearDiv := true
    prevRsiHigh    := currRsiHigh
    prevPriceHigh  := currPriceHigh
    prevRsiHighBar := bar_index - divMinBars

// Allow divergence signal to persist for a few bars after detection
var int bullDivBar = na
var int bearDivBar = na
if bullDiv
    bullDivBar := bar_index
if bearDiv
    bearDivBar := bar_index

bullDivRecent = not na(bullDivBar) and (bar_index - bullDivBar) <= 3
bearDivRecent = not na(bearDivBar) and (bar_index - bearDivBar) <= 3

// ============================================================================
// REGIME FILTERS
// ============================================================================

// Volatility regime: reject high-vol crash environments
atrRatio      = atrVal / atrSma
volRegimeOk   = atrRatio < atrMaxMult

// Volume spike on reversal candle
volSpike      = volume > volSma * volSpikeMult

// Trend context: use EMA to determine bias
aboveEma      = close > ema100
belowEma      = close < ema100

// ============================================================================
// ENTRY SIGNALS
// ============================================================================

// Bullish entry:
//   1. RSI bullish divergence detected recently
//   2. Volatility regime is not extreme
//   3. Volume spike on the entry candle (or within 1 bar)
//   4. RSI was below 40 at some point in the divergence (actually oversold territory)
//   5. Candle shows strength: close > open (bullish candle)
bullCandle   = close > open
volSpikeConf = volSpike or volSpike[1]
rsiWasLow    = ta.lowest(rsiVal, divLookback) < 40

longSignal = bullDivRecent and volRegimeOk and volSpikeConf and rsiWasLow and bullCandle

// Bearish entry:
//   1. RSI bearish divergence detected recently
//   2. Volatility regime is not extreme
//   3. Volume spike confirmation
//   4. RSI was above 60 at some point
//   5. Bearish candle
bearCandle   = close < open
rsiWasHigh   = ta.highest(rsiVal, divLookback) > 60

shortSignal = bearDivRecent and volRegimeOk and volSpikeConf and rsiWasHigh and bearCandle

// ============================================================================
// POSITION MANAGEMENT
// ============================================================================

var int   entryBar     = na
var float entryPrice   = na
var float stopLoss     = na
var float trailStop    = na
var float tpTarget     = na
var bool  trailActive  = false

// === LONG ENTRY ===
if longSignal and strategy.position_size == 0
    entryBar    := bar_index
    entryPrice  := close
    stopLoss    := close - atrVal * atrStopMult
    trailStop   := na
    trailActive := false
    // TP target: VWAP if above current price, otherwise entry + 2*ATR
    tpTarget    := vwapVal > close ? vwapVal : close + atrVal * 2.0
    strategy.entry("Long", strategy.long)

// === SHORT ENTRY ===
if shortSignal and strategy.position_size == 0
    entryBar    := bar_index
    entryPrice  := close
    stopLoss    := close + atrVal * atrStopMult
    trailStop   := na
    trailActive := false
    tpTarget    := vwapVal < close ? vwapVal : close - atrVal * 2.0
    strategy.entry("Short", strategy.short)

// ============================================================================
// EXIT LOGIC
// ============================================================================

barsInTrade = bar_index - nz(entryBar, bar_index)

// === LONG EXITS ===
if strategy.position_size > 0
    // Activate trailing stop once in profit by trailActivate * ATR
    if close > entryPrice + atrVal * trailActivate
        trailActive := true

    if trailActive
        newTrail = close - atrVal * atrTrailMult
        trailStop := na(trailStop) ? newTrail : math.max(trailStop, newTrail)

    // Check exits in priority order
    hitSL    = close <= stopLoss
    hitTrail = trailActive and not na(trailStop) and close <= trailStop
    hitTP    = close >= tpTarget
    hitTime  = barsInTrade >= maxBarsExit

    if hitSL
        strategy.close("Long", comment="SL")
        trailActive := false
        trailStop   := na
    else if hitTrail
        strategy.close("Long", comment="Trail")
        trailActive := false
        trailStop   := na
    else if hitTP
        strategy.close("Long", comment="TP-VWAP")
        trailActive := false
        trailStop   := na
    else if hitTime
        strategy.close("Long", comment="Time")
        trailActive := false
        trailStop   := na

// === SHORT EXITS ===
if strategy.position_size < 0
    if close < entryPrice - atrVal * trailActivate
        trailActive := true

    if trailActive
        newTrail = close + atrVal * atrTrailMult
        trailStop := na(trailStop) ? newTrail : math.min(trailStop, newTrail)

    hitSL    = close >= stopLoss
    hitTrail = trailActive and not na(trailStop) and close >= trailStop
    hitTP    = close <= tpTarget
    hitTime  = barsInTrade >= maxBarsExit

    if hitSL
        strategy.close("Short", comment="SL")
        trailActive := false
        trailStop   := na
    else if hitTrail
        strategy.close("Short", comment="Trail")
        trailActive := false
        trailStop   := na
    else if hitTP
        strategy.close("Short", comment="TP-VWAP")
        trailActive := false
        trailStop   := na
    else if hitTime
        strategy.close("Short", comment="Time")
        trailActive := false
        trailStop   := na

// ============================================================================
// PLOTS
// ============================================================================

// VWAP
plot(vwapVal, "VWAP", color=color.new(color.purple, 0), linewidth=2)
plot(ema100, "EMA 100", color=color.new(color.orange, 30), linewidth=1)

// Entry signals
plotshape(longSignal and strategy.position_size == 0, "Long Signal", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(shortSignal and strategy.position_size == 0, "Short Signal", shape.triangledown, location.abovebar, color.fuchsia, size=size.small)

// Divergence markers (on the bar they were detected, offset by pivot lag)
plotshape(bullDiv, "Bull Divergence", shape.diamond, location.belowbar, color.new(color.green, 30), size=size.tiny, offset=-divMinBars)
plotshape(bearDiv, "Bear Divergence", shape.diamond, location.abovebar, color.new(color.red, 30), size=size.tiny, offset=-divMinBars)

// Stop loss and trail visualization
plot(strategy.position_size > 0 ? stopLoss : na, "Long SL", color=color.red, style=plot.style_linebr, linewidth=1)
plot(strategy.position_size < 0 ? stopLoss : na, "Short SL", color=color.red, style=plot.style_linebr, linewidth=1)
plot(strategy.position_size != 0 and trailActive ? trailStop : na, "Trail Stop", color=color.orange, style=plot.style_linebr, linewidth=1)
plot(strategy.position_size != 0 ? tpTarget : na, "TP Target", color=color.new(color.teal, 40), style=plot.style_linebr, linewidth=1)

// Regime background
bgcolor(not volRegimeOk ? color.new(color.red, 95) : na, title="High Vol Warning")

// ============================================================================
// HIDDEN PLOTS FOR MCP
// ============================================================================

plot(rsiVal,       "RSI",           display=display.status_line, color=color.new(color.purple, 100))
plot(adxVal,       "ADX",           display=display.status_line, color=color.new(color.purple, 100))
plot(atrRatio,     "ATR Ratio",     display=display.status_line, color=color.new(color.purple, 100))
plot(atrVal,       "ATR",           display=display.status_line, color=color.new(color.purple, 100))
plot(vwapVal,      "VWAP Price",    display=display.status_line, color=color.new(color.purple, 100))
plot(bullDivRecent ? 1 : 0, "Bull Div Active", display=display.status_line, color=color.new(color.purple, 100))
plot(bearDivRecent ? 1 : 0, "Bear Div Active", display=display.status_line, color=color.new(color.purple, 100))
plot(volRegimeOk ? 1 : 0,   "Vol Regime OK",   display=display.status_line, color=color.new(color.purple, 100))
plot(volSpike ? 1 : 0,      "Vol Spike",       display=display.status_line, color=color.new(color.purple, 100))

// ============================================================================
// INFO TABLE
// ============================================================================

var table infoTbl = table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 20), border_width=1)

if barstate.islast
    rsiColor  = rsiVal > 60 ? color.red : rsiVal < 40 ? color.green : color.gray
    volColor  = volRegimeOk ? color.green : color.red
    volText   = volRegimeOk ? "NORMAL" : "HIGH VOL"
    trendText = aboveEma ? "BULLISH BIAS" : "BEARISH BIAS"
    trendClr  = aboveEma ? color.green : color.red

    posText = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    posClr  = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray

    signal = "NONE"
    sigColor = color.gray
    if longSignal and strategy.position_size == 0
        signal := "LONG ENTRY"
        sigColor := color.green
    else if shortSignal and strategy.position_size == 0
        signal := "SHORT ENTRY"
        sigColor := color.red
    else if bullDivRecent
        signal := "BULL DIV"
        sigColor := color.new(color.green, 40)
    else if bearDivRecent
        signal := "BEAR DIV"
        sigColor := color.new(color.red, 40)

    table.cell(infoTbl, 0, 0, "Metric",        text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 1, 0, "Value",          text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 0, 1, "Strategy",       text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 1, "RSI Div + VWAP", text_color=color.white, text_size=size.small)
    table.cell(infoTbl, 0, 2, "RSI",            text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 2, str.tostring(rsiVal, "#.#"), text_color=rsiColor, text_size=size.small)
    table.cell(infoTbl, 0, 3, "ADX",            text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 3, str.tostring(adxVal, "#.#"), text_color=color.gray, text_size=size.small)
    table.cell(infoTbl, 0, 4, "ATR Ratio",      text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 4, str.tostring(atrRatio, "#.##"), text_color=volColor, text_size=size.small)
    table.cell(infoTbl, 0, 5, "Vol Regime",     text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 5, volText,           text_color=volColor,    text_size=size.small)
    table.cell(infoTbl, 0, 6, "Trend (EMA)",    text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 6, trendText,         text_color=trendClr,    text_size=size.small)
    table.cell(infoTbl, 0, 7, "VWAP",           text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 7, str.tostring(vwapVal, format.mintick), text_color=color.purple, text_size=size.small)
    table.cell(infoTbl, 0, 8, "Signal",         text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 8, signal,            text_color=sigColor,    text_size=size.small)
    table.cell(infoTbl, 0, 9, "Position",       text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 9, posText,           text_color=posClr,      text_size=size.small)
    table.cell(infoTbl, 0, 10, "Bars in Trade", text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 10, strategy.position_size != 0 ? str.tostring(barsInTrade) : "-", text_color=color.gray, text_size=size.small)
    table.cell(infoTbl, 0, 11, "Timeframe",     text_color=color.gray,  text_size=size.small)
    table.cell(infoTbl, 1, 11, "1H / 4H",       text_color=color.white, text_size=size.small)
